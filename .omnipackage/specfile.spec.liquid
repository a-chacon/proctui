# RPM spec template rendered at build time.
# Cargo binary is `procman` (Cargo.toml [[bin]]), package name is also procman.
Name:       {{ package_name }}
Version:    {{ version }}
Release:    1%{?dist}
Summary:    {{ description }}
License:    GPL-3.0-or-later
URL:        {{ homepage }}
Source0:    {{ source_folder_name }}.tar.gz
Vendor:     OmniPackage

BuildRequires: {{ build_dependencies | join: ' ' }}
{% if runtime_dependencies.size > 0 %}
Requires: {{ runtime_dependencies | join: ', ' }}
{% endif %}

%define debug_package %{nil}
%define _build_id_links none

%description
{{ description }}


%prep
%setup -q


%build
cargo build --release


%install
install -d -m755 %{buildroot}/usr/bin/
install -m755 target/release/procman %{buildroot}/usr/bin/procman


%files
%attr(755, root, root) /usr/bin/procman


%changelog
* Wed Jun 24 2026 {{ maintainer }}
- Initial package release
